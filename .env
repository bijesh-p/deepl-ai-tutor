# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# LLM provider (Phase 1: anthropic only)
AI_TUTOR_LLM_PROVIDER=anthropic
AI_TUTOR_LLM_API_KEY=your-anthropic-api-key-here
AI_TUTOR_LLM_MODEL=claude-sonnet-4-6

# Admin credentials (used by the login page)
AI_TUTOR_ADMIN_USERNAME=admin
AI_TUTOR_ADMIN_PASSWORD=admin

# Storage paths (defaults shown — override if needed)
AI_TUTOR_DB_PATH=data/ai_tutor.db
AI_TUTOR_UPLOAD_DIR=data/uploads
AI_TUTOR_MAX_FILE_MB=50
