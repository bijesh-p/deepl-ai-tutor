# ── Option A: OpenAI (requires paid key) ──────────────────────────────────────
AI_TUTOR_LLM_PROVIDER=openai
AI_TUTOR_LLM_API_KEY=sk-...
AI_TUTOR_LLM_MODEL=gpt-4o

# ── Option B: Anthropic (requires paid key) ───────────────────────────────────
# AI_TUTOR_LLM_PROVIDER=anthropic
# AI_TUTOR_LLM_API_KEY=sk-ant-...
# AI_TUTOR_LLM_MODEL=claude-sonnet-4-6

# ── Option C: Ollama — free, runs locally, NO API key needed ─────────────────
# Install:  winget install Ollama.Ollama   (or brew install ollama on Mac)
# Pull model: ollama pull llama3.2
# Then start: ollama serve
# AI_TUTOR_LLM_PROVIDER=ollama
# AI_TUTOR_LLM_MODEL=llama3.2
# (leave AI_TUTOR_LLM_API_KEY unset)

# ── Option D: Demo mode — NO API key, NO internet, instant responses ──────────
# Returns plausible fake content so you can see the full UI flow immediately.
# AI_TUTOR_LLM_PROVIDER=demo
# (leave AI_TUTOR_LLM_API_KEY unset)

# ── Storage ───────────────────────────────────────────────────────────────────
AI_TUTOR_DB_PATH=data/ai_tutor.db
AI_TUTOR_UPLOAD_DIR=data/uploads
AI_TUTOR_MAX_FILE_MB=50
