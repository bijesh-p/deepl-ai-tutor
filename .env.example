# AI Tutor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Provider ────────────────────────────────────────────────────────────
# Choose: "anthropic" (direct Claude API) or "portkey" (Portkey gateway)
AI_TUTOR_LLM_PROVIDER=anthropic

# Claude model to use
AI_TUTOR_LLM_MODEL=claude-opus-4-8

# ── Anthropic Direct ─────────────────────────────────────────────────────────
# Required when AI_TUTOR_LLM_PROVIDER=anthropic
AI_TUTOR_LLM_API_KEY=your-anthropic-api-key-here

# ── Portkey Gateway ──────────────────────────────────────────────────────────
# Required when AI_TUTOR_LLM_PROVIDER=portkey
AI_TUTOR_PORTKEY_API_KEY=your-portkey-api-key-here
AI_TUTOR_PORTKEY_VIRTUAL_KEY=your-portkey-virtual-key-here

# ── Storage ──────────────────────────────────────────────────────────────────
AI_TUTOR_DB_PATH=data/ai_tutor.db
AI_TUTOR_UPLOAD_DIR=data/uploads
AI_TUTOR_MAX_FILE_MB=50
