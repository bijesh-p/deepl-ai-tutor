# AI Tutor — environment template.
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported: anthropic | portkey | ollama
AI_TUTOR_LLM_PROVIDER=anthropic

# ── Anthropic (direct) ────────────────────────────────────────────────────────
# Only needed when AI_TUTOR_LLM_PROVIDER=anthropic
AI_TUTOR_LLM_API_KEY=<API_KEY>
AI_TUTOR_LLM_MODEL=claude-sonnet-4-6

# ── Portkey (Anthropic SDK → Portkey gateway → any backend) ───────────────────
# Only needed when AI_TUTOR_LLM_PROVIDER=portkey
# Get your key from https://app.portkey.ai/
PORTKEY_API_KEY=your-portkey-api-key-here
# Model format for Vertex AI backend: @vertexai-global/anthropic.<model-name>
AI_TUTOR_PORTKEY_MODEL=@vertexai-global/anthropic.claude-sonnet-4-6

# ── Ollama (local, free) ──────────────────────────────────────────────────────
# Only needed when AI_TUTOR_LLM_PROVIDER=ollama
# Install: https://ollama.com/download  then: ollama pull llama3.2
AI_TUTOR_OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Model lists for sidebar dropdown (comma-separated) ───────────────────────
# Uncomment and edit to control which models appear in the UI selector.
# If unset, built-in defaults are used (see app.py _models_for_provider).
#AI_TUTOR_ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-8,claude-haiku-4-5-20251001
#AI_TUTOR_PORTKEY_MODELS=@vertexai-global/anthropic.claude-sonnet-4-6,@vertexai-global/anthropic.claude-haiku-4-5-20251001
#AI_TUTOR_OLLAMA_MODELS=llama3.2,qwen2.5,mistral

# ── Storage paths ────────────────────────────────────────────────────────────
# Per-user databases are created at <AI_TUTOR_DB_DIR>/<username>/ai_tutor.db
AI_TUTOR_DB_DIR=data
# Shared DB for admin-published modules (Phase 32)
#AI_TUTOR_SHARED_DB_PATH=data/shared/ai_tutor.db

# ── Admin mode (Phase 32) ─────────────────────────────────────────────────────
# Comma-separated usernames that require AI_TUTOR_ADMIN_PASSWORD at login to
# become admins. Admins can publish/unpublish their own modules to the shared
# library, visible to all users. Leave unset to disable admin mode entirely.
#AI_TUTOR_ADMIN_USERNAMES=admin
#AI_TUTOR_ADMIN_PASSWORD=change-me

# ── Max topics per module (Phase 55) ─────────────────────────────────────────
# Default value for the "Max topics" input on the upload page.
# 0 = unlimited (generate all topics from the document).
# Set to e.g. 5 for quick demos.
#AI_TUTOR_DEFAULT_MAX_TOPICS=0

# ── Guardrails (Phase 73) ────────────────────────────────────────────────────
# Master switch for all LLM input/output guardrail checks (prompt-injection,
# content moderation, topic-relevance, output-quality). false/0/no disables
# everything and restores raw passthrough behavior.
AI_TUTOR_GUARDRAILS_ENABLED=true
# Independent toggles for the two LLM-judge-based checks, in case one needs
# tuning/disabling without losing the other.
AI_TUTOR_GUARDRAILS_MODERATION_ENABLED=true
AI_TUTOR_GUARDRAILS_TOPIC_RELEVANCE_ENABLED=true

# ── Optional: LangSmith tracing (secondary, cloud) ───────────────────────────
#LANGCHAIN_TRACING_V2=true
#LANGCHAIN_API_KEY=ls-your-key-here
#LANGCHAIN_PROJECT=ai-tutor
